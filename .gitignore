# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment & secrets
.env
.env.local
.env.*.local
*.pem
*.key
service-account.json
service-account*.json
*-credentials.json
*-firebase-adminsdk*.json

# Logs
logs/
*.log

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp

# Build / temp
dist/
build/
.cache/
.tmp/
*.tmp

# Project-specific scratch
.git-commit-msg.tmp
_visual_captures/
LogoTemp/

# Test/dev capture & verify scripts (kept locally)
scripts/audit-*.mjs
scripts/capture-*.mjs
scripts/debug-*.mjs
scripts/diag-*.mjs
scripts/inspect-*.mjs
scripts/test-*.mjs
scripts/verify-*.mjs

# Antigravity / agent artifacts
.agents/
.gemini/

# Runtime data (DB, JSON stores, AI cache, backups)
data/*.db
data/*.db-journal
data/exams.json
data/questions.json
data/users.json
data/settings.json
data/ai-gen-cache.json
data/backups/

# Uploaded user content (keep folder, ignore contents)
public/uploads/*
!public/uploads/.gitkeep

# Local archive
_archive/

# IELTS local PDF sources — never committed, may contain copyrighted material.
# The folder + README + .gitkeep are tracked; files inside are not.
source-pdfs/**
!source-pdfs/.gitkeep
!source-pdfs/README.md
!source-pdfs/ielts/
!source-pdfs/ielts/README.md

# Legacy snapshots (pre-Postgres migration data dumps)
_legacy/

