# EasyRevise — Environment template
# Copy to .env and fill in real values. Never commit .env.

# ── Server ──────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# Public URL — must match the actual domain (used for OAuth redirect, QR codes, etc)
PUBLIC_BASE_URL=https://easyrise.thinhme.tech

# ── Postgres (Supabase) ─────────────────────────────────
# Direct connection (long-running queries)
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
# Pooled connection (transactions)
SUPABASE_DB_URL_TX=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── Auth ────────────────────────────────────────────────
# Random hex string, ≥256 bits.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Initial admin password (only used on first migration)
ADMIN_DEFAULT_PASSWORD=

# Optional: 6-digit PIN for /admin lock screen (leave empty to disable)
ADMIN_PIN=

# ── Google Drive ────────────────────────────────────────
# OAuth client credentials from console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Refresh token obtained from /admin/drive.html → Re-auth
GOOGLE_REFRESH_TOKEN=

# Drive folder ID where Kho Media stores all files (must be writable)
DRIVE_ROOT_FOLDER_ID=

# ── AI provider (Claude / OpenAI / Anthropic gateway) ───
CLAUDE_API_KEY=
CLAUDE_API_URL=https://api.loadip.com
CLAUDE_SDK_TYPE=anthropic
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Whisper (Speech-to-Text for IELTS Speaking) ─────────
# Free tier on Groq supports ~14400 minutes/day (whisper-large-v3-turbo).
# These can also be set per-environment via Admin → Settings UI.
WHISPER_BASE_URL=https://api.groq.com/openai/v1
WHISPER_API_KEY=
WHISPER_MODEL=whisper-large-v3-turbo

# ── Optional: Discord alerts ────────────────────────────
# Webhook URL for Drive health alerts and backup status
DISCORD_WEBHOOK_URL=

# ── Optional: Logging ───────────────────────────────────
# pino log level: trace, debug, info (default), warn, error
LOG_LEVEL=info
